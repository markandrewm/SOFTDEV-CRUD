@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
    <a asp-controller="Students" asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Add New Student
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-uppercase">Total Students</h6>
                <p class="display-5 mb-0">@ViewBag.TotalStudents</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-uppercase">Courses Offered</h6>
                <p class="display-5 mb-0">@ViewBag.TotalCourses</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-uppercase">Year Levels</h6>
                <p class="display-5 mb-0">@(((IDictionary<int,int>)ViewBag.YearLevelBreakdown).Count)</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header"><i class="bi bi-bar-chart-fill"></i> Students per Year Level</div>
            <ul class="list-group list-group-flush">
                @foreach (var kvp in (IDictionary<int, int>)ViewBag.YearLevelBreakdown)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Year @kvp.Key
                        <span class="badge bg-primary rounded-pill">@kvp.Value</span>
                    </li>
                }
                @if (((IDictionary<int, int>)ViewBag.YearLevelBreakdown).Count == 0)
                {
                    <li class="list-group-item text-muted">No data yet.</li>
                }
            </ul>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header"><i class="bi bi-clock-history"></i> Recently Added Students</div>
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Course</th>
                        <th>Date Added</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in (IEnumerable<StudentManagement.ViewModels.StudentDto>)ViewBag.RecentStudents)
                    {
                        <tr>
                            <td>@s.FirstName @s.LastName</td>
                            <td>@s.Course</td>
                            <td>@s.DateCreated.ToString("g")</td>
                        </tr>
                    }
                    @if (!((IEnumerable<StudentManagement.ViewModels.StudentDto>)ViewBag.RecentStudents).Any())
                    {
                        <tr><td colspan="3" class="text-muted">No students yet - click "Add New Student" to get started.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
