@model StudentDto
@{
    ViewData["Title"] = "Delete Student";
}

<h1 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Delete Student</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this student? This action cannot be undone from the UI.
</div>

<div class="card shadow-sm" style="max-width: 600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Student Number</dt>
            <dd class="col-sm-8">@Model.StudentNumber</dd>

            <dt class="col-sm-4">Full Name</dt>
            <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Course</dt>
            <dd class="col-sm-8">@Model.Course</dd>
        </dl>
    </div>
    <div class="card-footer">
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="StudentId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Cancel</a>
        </form>
    </div>
</div>
