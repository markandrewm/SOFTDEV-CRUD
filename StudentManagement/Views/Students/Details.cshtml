@model StudentDto
@{
    ViewData["Title"] = "Student Details";
}

<h1><i class="bi bi-person-lines-fill"></i> Student Details</h1>

<div class="card shadow-sm" style="max-width: 600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Student Number</dt>
            <dd class="col-sm-8">@Model.StudentNumber</dd>

            <dt class="col-sm-4">Full Name</dt>
            <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Course</dt>
            <dd class="col-sm-8">@Model.Course</dd>

            <dt class="col-sm-4">Year Level</dt>
            <dd class="col-sm-8">@Model.YearLevel</dd>

            <dt class="col-sm-4">Date Created</dt>
            <dd class="col-sm-8">@Model.DateCreated.ToString("f")</dd>

            <dt class="col-sm-4">Last Updated</dt>
            <dd class="col-sm-8">@(Model.DateUpdated.HasValue ? Model.DateUpdated.Value.ToString("f") : "Never")</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>
</div>
